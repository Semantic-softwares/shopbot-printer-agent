# ShopBot Printer - Environment Configuration

# Backend API Configuration
API_BASE_URL=http://localhost:3000

# Store Configuration
# IMPORTANT: Each printer instance must be assigned to a specific store
# This store ID is currently hardcoded in main.js as HARDCODED_STORE_ID
# To configure for a different store, update the hardcoded value in pollPrintJobs()
STORE_ID=695b7b1063e53f499a18634b

# Device Configuration
DEVICE_ID=printer-device-001

# Polling Configuration
POLL_INTERVAL=3000
LOG_LEVEL=INFO

# Printer Configuration
ENABLE_USB_DISCOVERY=true
ENABLE_NETWORK_DISCOVERY=false
NETWORK_SUBNET=192.168.1
